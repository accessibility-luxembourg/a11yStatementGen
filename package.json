{
  "name": "a11ystatementgen",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "scripts": {
    "build": "bash ./build.sh",
    "watch:dev": "npm-watch",
    "watch": "concurrently -k 'npm:serve' 'npm:watch:dev'",
    "serve": "http-server ./dist",
    "clean": "rm -fr ./dist/*"
  },
  "watch": {
    "build": {
      "patterns": [
        "src/tpl",
        "src/css",
        "src/js",
        "content"
      ],
      "extensions": [
        "js",
        "ejs",
        "md",
        "scss",
        "json"
      ]
    }
  },
  "author": "Information and press service",
  "license": "MIT",
  "dependencies": {
    "ejs": "^5.0.1",
    "y18n": "^5.0.8"
  },
  "devDependencies": {
    "concurrently": "^5.3.0",
    "http-server": "^14.1.1",
    "npm-watch": "^0.13.0"
  }
}
